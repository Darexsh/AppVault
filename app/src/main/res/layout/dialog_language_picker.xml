<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_storage_permission_dialog"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="16dp"
    android:paddingEnd="18dp"
    android:paddingBottom="14dp">

    <TextView
        android:id="@+id/language_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/language_title"
        android:textColor="#EEF3FF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/language_dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="14dp"
        android:text="@string/language_message"
        android:textColor="#D9E4F9"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/language_system_button"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="38dp"
        android:text="@string/language_system"
        android:textAllCaps="false"
        android:textColor="#D7E1F6"
        app:cornerRadius="14dp"
        app:strokeColor="#50607D" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/language_english_button"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="38dp"
        android:text="@string/language_english"
        android:textAllCaps="false"
        android:textColor="#D7E1F6"
        app:cornerRadius="14dp"
        app:strokeColor="#50607D" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/language_german_button"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="38dp"
        android:text="@string/language_german"
        android:textAllCaps="false"
        android:textColor="#D7E1F6"
        app:cornerRadius="14dp"
        app:strokeColor="#50607D" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/language_cancel_button"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:minHeight="36dp"
        android:text="@android:string/cancel"
        android:textAllCaps="false"
        android:textColor="#B7C7E4"
        app:cornerRadius="14dp"
        app:strokeColor="#394965" />

</LinearLayout>
