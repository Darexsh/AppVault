<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="11dp"
    android:paddingBottom="11dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/app_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@null"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/app_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#EAF1FF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/app_package"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#B7C6E3"
                android:textSize="12sp"
                android:textStyle="italic" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/app_expand_button"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/app_actions_expand"
            android:padding="6dp"
            android:src="@android:drawable/arrow_down_float"
            android:tint="#B7C6E3" />

        <CheckBox
            android:id="@+id/app_select_checkbox"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:buttonTint="#AFC6EA"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/app_actions_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/action_settings"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/app_action_settings"
            android:textAllCaps="false"
            android:textColor="#C8D4EC"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="16dp"
            app:iconTint="#C8D4EC"
            app:strokeColor="#30405E" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/action_backup"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/app_action_backup"
            android:textAllCaps="false"
            android:textColor="#C8D4EC"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="16dp"
            app:iconTint="#C8D4EC"
            app:strokeColor="#30405E" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/action_uninstall"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_action_uninstall"
            android:textAllCaps="false"
            android:textColor="#FF7E7E"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="16dp"
            app:iconTint="#FF7E7E"
            app:strokeColor="#AA5A5A" />
    </LinearLayout>

</LinearLayout>
