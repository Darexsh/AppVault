<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="30dp"
    android:paddingEnd="16dp"
    android:paddingBottom="26dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/header_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:strokeColor="#22FFFFFF"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@android:color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_app_info"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/round_icon_button"
                    android:contentDescription="@string/settings_info_desc"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:text="i"
                    android:textColor="#1A273B"
                    android:textSize="18sp"
                    android:textStyle="bold|italic" />
            </RelativeLayout>

            <TextView
                android:id="@+id/header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/header_subtitle"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/search_field_container"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/search"
                    app:expandedHintEnabled="false"
                    app:hintAnimationEnabled="false"
                    app:boxBackgroundColor="#22FFFFFF"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="#66FFFFFF"
                    app:hintTextColor="#CCFFFFFF"
                    app:hintTextAppearance="@style/TextAppearance.AppsInspector.FieldLabel"
                    app:placeholderText="@string/search_placeholder"
                    app:placeholderTextColor="#B3FFFFFF"
                    app:startIconDrawable="@android:drawable/ic_menu_search"
                    app:startIconTint="@android:color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/search_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:textColor="@android:color/white"
                        android:textColorHint="#B3FFFFFF" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/filter_dropdown_container"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/filter_hint"
                        app:expandedHintEnabled="false"
                        app:hintAnimationEnabled="false"
                        app:boxBackgroundColor="#22FFFFFF"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="#66FFFFFF"
                        app:hintTextColor="#CCFFFFFF"
                        app:hintTextAppearance="@style/TextAppearance.AppsInspector.FieldLabel">

                        <AutoCompleteTextView
                            android:id="@+id/filter_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:focusable="false"
                            android:inputType="none"
                            android:saveEnabled="false"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:textColor="@android:color/white"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/sort_dropdown_container"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:hint="@string/sort_hint"
                        app:expandedHintEnabled="false"
                        app:hintAnimationEnabled="false"
                        app:boxBackgroundColor="#22FFFFFF"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="#66FFFFFF"
                        app:hintTextColor="#CCFFFFFF"
                        app:hintTextAppearance="@style/TextAppearance.AppsInspector.FieldLabel">

                        <AutoCompleteTextView
                            android:id="@+id/sort_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:focusable="false"
                            android:inputType="none"
                            android:saveEnabled="false"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp"
                            android:textColor="@android:color/white"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/batch_actions_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="#0F1628"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:strokeColor="#25304A"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/batch_selection_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#D7E4FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="4">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/batch_select_all"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:minHeight="34dp"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/batch_select_all"
                        android:textAllCaps="false"
                        android:textColor="#C8D4EC"
                        android:textSize="12sp"
                        app:strokeColor="#30405E" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/batch_clear"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:minHeight="34dp"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/batch_clear"
                        android:textAllCaps="false"
                        android:textColor="#C8D4EC"
                        android:textSize="12sp"
                        app:strokeColor="#30405E" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/batch_backup"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:minHeight="34dp"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/batch_backup"
                        android:textAllCaps="false"
                        android:textColor="#C8D4EC"
                        android:textSize="12sp"
                        app:strokeColor="#30405E" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/batch_uninstall"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="34dp"
                        android:minWidth="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/batch_uninstall"
                        android:textAllCaps="false"
                        android:textColor="#FF8E8E"
                        android:textSize="12sp"
                        app:strokeColor="#AA5A5A" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#0F1628"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:strokeColor="#25304A"
        app:strokeWidth="1dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="10dp">

            <ListView
                android:id="@+id/app_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:divider="@drawable/list_divider_subtle"
                android:dividerHeight="1dp"
                android:paddingBottom="8dp"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/empty_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/no_apps_found"
                android:textColor="#B9C5DD"
                android:textAppearance="@style/TextAppearance.AppCompat.Body1" />
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
